// JarvisMetaBridge.xcconfig
//
// The single place to set your signing + Meta credentials. These flow into the
// build settings and into Info.plist ($(DEVELOPMENT_TEAM), $(CLIENT_TOKEN),
// $(META_APP_ID)). Fill them in, or set the same values in Xcode's Signing &
// Capabilities tab.

// --- Apple signing ---
// Your 10-character Apple Developer Team ID (auto-detected from your codesigning
// identity: Jonathan Kfir). Change only if you build under a different team.
DEVELOPMENT_TEAM = 3K8N98ZS5T

// A unique reverse-DNS bundle identifier you control. Change if you like — it
// just needs to be unique on your Apple developer team.
PRODUCT_BUNDLE_IDENTIFIER = com.jonakfir.JarvisMetaBridge

// --- Meta Wearables DAT credentials ---
// Keep real Wearables Developer Center values in the ignored local override.
// This prevents credentials from being committed to the public repository.
CLIENT_TOKEN =
META_APP_ID =

#include? "JarvisMetaBridge.local.xcconfig"
