<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Glasses Widgets</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>JarvisMetaBridge</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- App-link URL scheme used by the Meta DAT registration callback. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>jarvismetabridge</string>
			</array>
		</dict>
	</array>
	<!-- Meta Wearables Device Access Toolkit configuration. -->
	<!-- Values must match the project registered in Wearables Developer Center. -->
	<key>MWDAT</key>
	<dict>
		<key>DAMEnabled</key>
		<true/>
		<key>AppLinkURLScheme</key>
		<string>https://jarvis-meta-bridge-links.vercel.app/meta-wearables/callback</string>
		<key>ClientToken</key>
		<string>$(CLIENT_TOKEN)</string>
		<key>MetaAppID</key>
		<string>$(META_APP_ID)</string>
		<key>TeamID</key>
		<string>$(DEVELOPMENT_TEAM)</string>
	</dict>
	<!-- Required so the DAT SDK can detect and open the Meta AI companion app. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>fb-viewapp</string>
	</array>
	<!-- Allow plaintext HTTP to your Mac on the local network (dev backend). -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Prompt shown when connecting to Meta glasses over Bluetooth. -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Needed to connect to your Meta AI glasses.</string>
	<!-- Prompt shown for discovering the JARVIS backend on the local network. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Needed to send camera frames to the JARVIS backend running on your Mac.</string>
	<!-- Microphone (Voice Guide) — captures your spoken question via the glasses/phone mic. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Needed for the Voice Guide widget to hear your spoken questions.</string>
	<!-- On-device speech recognition for the Voice Guide widget. -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Needed to transcribe your spoken questions on device for the Voice Guide widget.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Required so the glasses connection survives backgrounding. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-peripheral</string>
		<string>external-accessory</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- Meta wearables communicate over the External Accessory protocol. -->
	<key>UISupportedExternalAccessoryProtocols</key>
	<array>
		<string>com.meta.ar.wearable</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
